string :: 

json :: in <-> out
	null :: .. 'null'
	integer :: .. '0'~'9'
	decimal :: .. integer ('.' '0'~'9' 'f'?) 
	object  :: ..
		'{'
			out <- object {
				key_pair: .. [key:string ":" value:value ","]* =>
					out <- key = decode(key), value = parse_type($value)
			}
			
		'}'
	array :: .. 
		'[' out <- array { 
				value: .. [v: value ","]* 
				out <- parse_value(v) 
			} 
		']'
	
json.null 	 :: 'null' 							<-> null
json.integer :: ('0'~'9'+) 						<-> i64
json.decimal :: json.integer ('.' '0'~'9' 'f'?) <-> f64
json.number  :: json.integer | json_decimal
json.object  :: '{' 
					@object_begin 
					[json.string ':' json.value ',']+
					@object_end 
				'}' 							<-> (key = json.string, value = json.value)





json.value   :: json.null | json.number | json.object | json.array | json.bool
json.number  :: json.integer | json.decimal
json.bool 	 :: bool 		<-> ('true': @true) | ('false': @false)	
json.null 	 :: null 		<-> 'null'
json.integer :: i64  		<-> ('0'~'9'+)
json.decimal :: f64  		<-> json.integer ('.' '0'~'9' 'f'?)
json.array	 :: [value]* 	<-> '[' [json.value ","]* ']'
json.object  :: object[]* 	<-> '{' 
	@object {
		[json.string ':' json.value ',']+
	} 
'}'



json :: in <-> out
	null :: .. 'null'
	integer :: .. '0'~'9'+
	decimal :: .. integer ('.' '0'~'9' 'f'?) 
	object  :: ..
		'{'
			@object {
				key_pair: .. [key:string ":" value:value ","]* =>
					out @json_pair = decode(key), value = parse_type($value)
			}
			
		'}'
	array :: .. 
		'[' @array { 
				value: .. [v: value ","]* 
				@parse_value(v) 
			} 
		']'
	
	
	
	