json.number: '0'~'9' '.' '0'~'9' 'f'
json.string: '"'

\w :: ["\n", "\r", " ", "\t"]

json {
	number: ('0'~'9') '.' ('0'~'9' 'f')?  
	string: '"' !'\\' '"'
	bool: "true" | "false"
	null: "null"
	object: "{" \w [key_pair .* ","] \w  ','? \w "}"
	key_pair = key: string \w ":" \w value: value
	array: "[" \w [value .* ","] \w "]"
	value: number | string | bool | null | object | array
}



json_number: ('0'~'9') .. ('.' .. '0'~'9' .. 'f')?
json_string: '"' .. !['\\"'] .. '""'
json_boolean: "true" | "false"
json_null: "null"
json_object: '{' .* (key=json_string .. ":" .. value=json_value .. "," ) .. "}"
json_array: '[' .* (value=json_value .. ",") .. ']'
json_value: json_number | json_string | json_null | json_boolean | json_array | json_object


